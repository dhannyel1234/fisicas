# =============================================================================
# CONFIGURAÇÕES DO DISCORD OAUTH2
# Obtenha em: https://discord.com/developers/applications
# =============================================================================
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# =============================================================================
# CONFIGURAÇÕES DO BANCO DE DADOS
# =============================================================================
DATABASE_URL=postgresql://hyperv_user:hyperv_password123@localhost:5432/hyperv_platform

# =============================================================================
# CONFIGURAÇÕES DO REDIS
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# CONFIGURAÇÕES DE SEGURANÇA
# =============================================================================
JWT_SECRET=hyperv_jwt_secret_key_change_in_production
SESSION_SECRET=hyperv_session_secret_change_in_production

# =============================================================================
# CONFIGURAÇÕES DO HYPER-V (para o agente)
# =============================================================================
HYPERV_HOST=your-hyperv-server-ip-or-hostname
HYPERV_USERNAME=Administrator
HYPERV_PASSWORD=your_hyperv_admin_password
BASE_VM_IMAGE_PATH=C:\VMs\BaseImage\base.vhdx
VM_SWITCH_NAME=Default Switch
VM_RAM_MB=4096
VM_CPU_CORES=2
VM_STORAGE_PATH=C:\VMs\Instances\

# =============================================================================
# CONFIGURAÇÕES DE REDE DAS VMs
# =============================================================================
VM_IP_RANGE_START=192.168.1.100
VM_IP_RANGE_END=192.168.1.200
VM_SUBNET_MASK=255.255.255.0
VM_GATEWAY=192.168.1.1
VM_DNS_SERVERS=8.8.8.8,8.8.4.4

# =============================================================================
# CONFIGURAÇÕES DA APLICAÇÃO
# =============================================================================
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# =============================================================================
# CONFIGURAÇÕES DE EMAIL (OPCIONAL)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# =============================================================================
# CONFIGURAÇÕES DE MONITORAMENTO (OPCIONAL)
# =============================================================================
ENABLE_METRICS=true
ENABLE_LOGS=true
LOG_LEVEL=info

# =============================================================================
# CONFIGURAÇÕES DE LIMITES
# =============================================================================
MAX_VMS_PER_USER=1
MAX_VM_SESSION_HOURS=4
MAX_QUEUE_SIZE=50
VM_CREATION_TIMEOUT_MINUTES=10