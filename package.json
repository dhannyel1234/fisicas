{
  "name": "hyperv-platform",
  "version": "1.0.0",
  "description": "Plataforma de acesso remoto via máquinas virtuais Hyper-V",
  "private": true,
  "workspaces": [
    "frontend",
    "backend", 
    "hyper-v-agent",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:agent": "cd hyper-v-agent && npm run dev",
    "build": "npm run build:shared && npm run build:backend && npm run build:frontend",
    "build:shared": "cd shared && npm run build",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "install:all": "npm install && npm run install:workspaces",
    "install:workspaces": "npm install --workspaces",
    "clean": "rm -rf node_modules frontend/node_modules backend/node_modules hyper-v-agent/node_modules shared/node_modules",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "@types/node": "^20.10.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Hyper-V Platform Team",
  "license": "PROPRIETARY"
}